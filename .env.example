# ============================================================
#  Fiber Tracker — Environment Variables Template
#  Copy to .env and fill in real values.
#  .env is gitignored — never commit secrets.
# ============================================================

# ---- PostgreSQL ----
# Docker Compose (internal): DB_HOST=db, DB_PORT=5432
# Local dev (outside Docker): DB_HOST=localhost, DB_PORT=5444
DB_HOST=db
DB_PORT=5432
DB_USER=fiber_admin
DB_PASSWORD=changeme
DB_NAME=fiber_tracker

# ---- Zitadel ----
# Master key MUST be exactly 32 characters.  Rotate before production.
ZITADEL_MASTER_KEY=01234567890123456789012345678912

# Service Account PAT — Zitadel Console → Service Users → Create PAT
# Required scope: IAM_OWNER (so the app can call /v2/sessions)
ZITADEL_SERVICE_PAT=your_service_account_pat

# OIDC Web SSO — Zitadel Console → Applications → Web → Client ID/Secret
OIDC_CLIENT_ID=your_client_id
OIDC_CLIENT_SECRET=your_client_secret
OIDC_ISSUER_URL=http://zitadel.localhost:8080
OIDC_REDIRECT_URI=http://localhost:9510/api/auth/callback

# ---- SMTP ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com

# ---- App ----
PORT=9510
# Used only on first boot to seed the admin user (leave blank after first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
